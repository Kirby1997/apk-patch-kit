# Binary APK inputs — vendor IP, not distributable
apps/*/apks/*.apk
apps/*/apks/*.apks
apps/*/apks/*.xapk

# Decompiled dumps — regeneratable from the APK
apps/*/decompiled-*/
apps/*/hidratenow_decompiled/

# Build outputs
build/
**/build/
.gradle/
.kotlin/

# All jars excluded — revanced-cli, built patches, any other tooling jars.
# The gradle wrapper jar is the one exception (needed to bootstrap ./gradlew
# on a fresh clone).
*.jar
!gradle/wrapper/gradle-wrapper.jar

# Upstream ReVanced patches bundles downloaded to repo root for apps that
# consume them directly instead of having a patches/<app>/ subproject.
*.rvp

# IDE / editor
.idea/
*.iml
.vscode/

# OS
.DS_Store
Thumbs.db

# Signing artefacts (the driver regenerates these per-run)
*.p12
*.keystore
*.jks

# Local settings
.claude/settings.local.json

# Personal scratchpad
TODO.md
